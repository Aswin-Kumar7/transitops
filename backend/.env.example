# ─── Neon PostgreSQL ────────────────────────────────────────────────
# Pooled connection (used by the app at runtime).
# Get this from your Neon project dashboard -> Connection Details.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/transitops?sslmode=require"

# Direct (unpooled) connection — used by Prisma for migrations only.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/transitops?sslmode=require"

# ─── Auth (implemented in code, not via Neon) ───────────────────────
# Use a long random string. Generate one with:  openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="8h"

# Account lockout policy
MAX_FAILED_LOGINS="5"
LOCKOUT_MINUTES="15"

# ─── Server ─────────────────────────────────────────────────────────
PORT="4000"
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"
