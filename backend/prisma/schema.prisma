// TransitOps data model
// Neon (PostgreSQL) is used strictly as the database. Auth, RBAC and all
// business logic live in the API layer (src/). See docs/ARCHITECTURE.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────
//  Enums
// ─────────────────────────────────────────────────────────────────────

enum Role {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleType {
  VAN
  TRUCK
  MINI
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum LicenseCategory {
  LMV // Light Motor Vehicle
  HMV // Heavy Motor Vehicle
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  IN_SHOP // service ongoing — vehicle pulled from dispatch pool
  COMPLETED // service closed — vehicle returned to AVAILABLE
}

enum ExpenseCategory {
  TOLL
  FUEL
  MAINTENANCE
  MISC
}

// ─────────────────────────────────────────────────────────────────────
//  Auth  (owned by base)
// ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)

  // Lockout state — enforced in code (auth.service.ts)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?

  createdTrips Trip[] @relation("TripCreatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

// ─────────────────────────────────────────────────────────────────────
//  Fleet  (owned by Member 1)
// ─────────────────────────────────────────────────────────────────────

model Vehicle {
  id              String        @id @default(cuid())
  registrationNo  String        @unique // e.g. GJ01AB4521 — must be unique
  name            String // model/label, e.g. VAN-05
  type            VehicleType
  capacityKg      Int // max cargo weight
  odometer        Int           @default(0)
  acquisitionCost Decimal       @db.Decimal(12, 2)
  status          VehicleStatus @default(AVAILABLE)
  region          String? // operating zone/depot region — used by dashboard filters

  trips          Trip[]
  maintenance    MaintenanceRecord[]
  fuelLogs       FuelLog[]
  expenses       Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([region])
}

model MaintenanceRecord {
  id          String            @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  serviceType String // e.g. Oil Change, Engine Repair, Tyre Replace
  cost        Decimal           @db.Decimal(12, 2)
  serviceDate DateTime
  status      MaintenanceStatus @default(IN_SHOP)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────
//  Drivers  (owned by Member 2)
// ─────────────────────────────────────────────────────────────────────

model Driver {
  id              String          @id @default(cuid())
  name            String
  licenseNo       String          @unique
  licenseCategory LicenseCategory
  licenseExpiry   DateTime
  contact         String
  tripCompletionRate Decimal      @default(0) @db.Decimal(5, 2) // percent 0..100
  status          DriverStatus    @default(AVAILABLE)

  trips Trip[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────
//  Trips  (owned by Member 2)
// ─────────────────────────────────────────────────────────────────────

model Trip {
  id             String     @id @default(cuid())
  tripCode       String     @unique // e.g. TR001
  source         String
  destination    String
  cargoWeightKg  Int
  plannedDistanceKm Int
  status         TripStatus @default(DRAFT)
  revenue        Decimal?   @db.Decimal(12, 2)

  // Odometer snapshots — captured on complete
  startOdometer Int?
  endOdometer   Int?

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
  driverId  String?
  driver    Driver?  @relation(fields: [driverId], references: [id])

  createdById String?
  createdBy   User?   @relation("TripCreatedBy", fields: [createdById], references: [id])

  dispatchedAt DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?

  fuelLogs FuelLog[]
  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
}

// ─────────────────────────────────────────────────────────────────────
//  Fuel & Expenses  (owned by Member 3)
// ─────────────────────────────────────────────────────────────────────

model FuelLog {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  tripId    String?
  trip      Trip?    @relation(fields: [tripId], references: [id])
  date      DateTime
  liters    Decimal  @db.Decimal(8, 2)
  cost      Decimal  @db.Decimal(12, 2)
  odometer  Int? // odometer reading at fill-up, for efficiency calc

  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([tripId])
}

model Expense {
  id        String          @id @default(cuid())
  vehicleId String
  vehicle   Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  tripId    String?
  trip      Trip?           @relation(fields: [tripId], references: [id])
  category  ExpenseCategory
  toll      Decimal         @default(0) @db.Decimal(12, 2)
  other     Decimal         @default(0) @db.Decimal(12, 2)
  note      String?
  date      DateTime        @default(now())

  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([tripId])
}

// ─────────────────────────────────────────────────────────────────────
//  Settings  (owned by base / Member 3 for UI)
// ─────────────────────────────────────────────────────────────────────

model Setting {
  id           Int      @id @default(1) // singleton row
  depotName    String   @default("Gandhinagar Depot GJ4")
  currency     String   @default("INR")
  distanceUnit String   @default("Kilometers")

  updatedAt DateTime @updatedAt
}
